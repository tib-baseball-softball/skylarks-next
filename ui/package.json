{
  "name": "skylarks-diamond-planner",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build:prod": "vite build",
    "build:staging": "vite build --mode staging",
    "extract": "dotenvx run -- wuchale",
    "clean": "dotenvx run -- wuchale --clean",
    "preview": "vite preview",
    "test": "dotenvx run -- vitest && pnpm test:e2e",
    "sv-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "generate:types": "typed-pocketbase -d src/lib/model",
    "test:e2e": "dotenvx run -- playwright test",
    "test:ui": "dotenvx run -- playwright test --ui",
    "test:unit": "dotenvx run -- vitest",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@dotenvx/dotenvx": "^1.66.0",
    "@dragdroptouch/drag-drop-touch": "^2.0.3",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tigawanna/typed-pocketbase": "^0.1.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "24.10.1",
    "@vincjo/datatables": "^2.8.0",
    "@wuchale/svelte": "^0.19.4",
    "bits-ui": "^2.18.1",
    "bsm.js": "^0.4.0",
    "carta-md": "^4.11.2",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.5",
    "flatpickr": "^4.6.13",
    "leaflet": "^1.9.4",
    "lucide-svelte": "^1.0.1",
    "micromark": "^4.0.2",
    "pocketbase": "^0.26.9",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "svelte-persisted-state": "^1.4.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wuchale": "^0.23.4"
  },
  "type": "module",
  "overrides": {
    "typed-pocketbase": {
      "pocketbase": "$pocketbase"
    }
  }
}
