### fallback for events ###
TIME_ZONE="Europe/Berlin"

### global instance only used for TiB relay, individual clubs can provide their own  ###
BSM_API_KEY=""

### keys for WebPush notifications ###
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
