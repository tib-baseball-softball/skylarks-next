BSM_API_HOST="bsm.baseball-softball.de"
PUBLIC_TYPO3_URL="https://skylarks-hp.ddev.site"

### determines several logging details ###
APPLICATION_CONTEXT="Development"

### a very long string that should be impossible to guess ###
